# Phone reminders (optional). When unset, the app continues to work
# locally and only foreground reminder sounds will play.
#
# Create a Supabase project, then:
#   1. Run supabase/migrations/0001_phone_reminders.sql in the SQL editor.
#   2. Generate a VAPID key pair (web-push generate-vapid-keys) and store the
#      public key here. The private key goes in the Edge Function env.
#   3. Deploy supabase/functions/send-reminders and schedule it (e.g. every
#      minute via pg_cron or Supabase Scheduled Triggers).
#
# Public values — safe to ship in the client bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=

# Edge Function secrets (set with `supabase secrets set ...`, NOT in this file
# when deployed). Reference for local development:
# SUPABASE_SERVICE_ROLE_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
